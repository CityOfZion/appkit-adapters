{
  "name": "@cityofzion/appkit-neox-adapter",
  "version": "1.0.0",
  "description": "AppKit adapter for Stellar blockchain",
  "author": "Raul Duarte Pereira (https://github.com/raulduartep)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CityOfZion/appkit-adapters.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "appkit",
    "wallet",
    "dapps",
    "web3",
    "neox",
    "blockchain",
    "adapter"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/esm/index.js",
  "types": "./dist/types/exports/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/CityOfZion/appkit-adapters/issues"
  },
  "homepage": "https://github.com/CityOfZion/appkit-adapters/packages/appkit-neox-adapter#readme",
  "scripts": {
    "build": "rm -rf ./dist && npm run typecheck && tsc --project tsconfig.json",
    "format": "eslint --fix",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "neox-tpke": "^1.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^25.1.0",
    "@walletconnect/types": "^2.23.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1"
  },
  "peerDependencies": {
    "@reown/appkit": "*",
    "@reown/appkit-common": "*",
    "@reown/appkit-controllers": "*",
    "@walletconnect/universal-provider": "*",
    "viem": "*",
    "@wagmi/core": "*"
  }
}
